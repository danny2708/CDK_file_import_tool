        input[type=button], input[type=submit], button { border-radius: 5px 5px; border: 1px solid #FFF; background-color: #ED1C24; font-size: 14px; color: #FFF; }
        .title-head { font: normal 22px/25px Roboto,Arial,Tahoma; text-transform: uppercase; color: #FFF; text-align: center; padding-bottom: 20px; }
        .ms-inputuserfield { border: 1px solid #dfdfdf; border-radius: 3px; margin: 5px auto; background: #FFF; }
